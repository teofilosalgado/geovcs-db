    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug GeoVCS Database",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "output": "${workspaceFolder}/bin/dolt",
            "program": "github.com/dolthub/dolt/go/cmd/dolt",
            "cwd": "${workspaceFolder}/bin",
            "env": {
                "CGO_ENABLED": "1"
            },
            "args": [
                "sql-server",
                "--loglevel",
                "debug"
            ]
        }
    ]
}